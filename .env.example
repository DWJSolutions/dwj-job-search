# ═══════════════════════════════════════════════════════════════
#  DWJ Job Search App — Environment Variables
#  Copy this file to .env and fill in your keys
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Job API Keys ───────────────────────────────────────────────
# Adzuna: register at https://developer.adzuna.com (free, instant)
ADZUNA_APP_ID=YOUR_ADZUNA_APP_ID
ADZUNA_APP_KEY=YOUR_ADZUNA_APP_KEY

# ZipRecruiter: apply at https://www.ziprecruiter.com/partner (1–3 day approval)
ZIPRECRUITER_API_KEY=YOUR_ZIPRECRUITER_API_KEY

# USAJOBS: register at https://developer.usajobs.gov (free, instant)
USAJOBS_API_KEY=YOUR_USAJOBS_API_KEY
USAJOBS_USER_AGENT=your-email@example.com

# ─── AI ─────────────────────────────────────────────────────────
# OpenAI: https://platform.openai.com (pay-as-you-go, ~$0.005/resume)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ─── Geocoding ───────────────────────────────────────────────────
# OpenCage (optional fallback): https://opencagedata.com (2,500 free/day)
OPENCAGE_API_KEY=YOUR_OPENCAGE_API_KEY

# ─── Database ────────────────────────────────────────────────────
# Supabase (recommended): https://supabase.com — free tier 500MB
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/dwj_jobs

# ─── App Config ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
PYTHON_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Default Location (Orlando, FL) ──────────────────────────────
DEFAULT_ZIP=32801
DEFAULT_CITY=Orlando
DEFAULT_STATE=FL
